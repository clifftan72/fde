{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.fde.sg" }],
      "destination": "https://fde.sg/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "fde.com.sg" }],
      "destination": "https://fde.sg/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.fde.com.sg" }],
      "destination": "https://fde.sg/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": ".*\\.vercel\\.app" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|sitemap.xml|robots.txt|llms.txt|favicon.svg|og-image.png).*)",
      "destination": "/index.html"
    }
  ]
}
